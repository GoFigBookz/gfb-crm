# Enterprise Bookkeeper CRM - Environment Configuration
# Copy this file to .env and fill in your values

# === Database ===
DATABASE_URL=mysql://root:your_password@localhost:3306/bookkeeper_crm

# === Application ===
NODE_ENV=production
VITE_APP_URL=http://localhost:3000
APP_SECRET=your-super-secret-jwt-key-change-this-in-production

# === Kimi OAuth (for authentication) ===
VITE_KIMI_AUTH_URL=https://portal.your-domain.com
VITE_APP_ID=your-app-id

# === Google OAuth (for Gmail, Calendar, Drive integration) ===
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === Microsoft OAuth (for Outlook, Calendar, OneDrive integration) ===
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# === QuickBooks Online (native per-realm OAuth) ===
# Production Intuit app credentials. Redirect URI must match the Intuit app:
#   https://figgy.gofig.ca/api/qbo/callback   (set QBO_REDIRECT_URI to override)
QBO_CLIENT_ID=your-intuit-app-client-id
QBO_CLIENT_SECRET=your-intuit-app-client-secret
# QBO_REDIRECT_URI=https://figgy.gofig.ca/api/qbo/callback
# Encrypts QBO tokens at rest (AES-256-GCM) and signs OAuth state (HMAC).
# Falls back to APP_SECRET if unset; production MUST set one of them.
FIGGY_TOKEN_KEY=a-long-random-secret-for-token-encryption

# === AI Agent Integration ===
# Optional: Configure webhook endpoints for your AI agents
AI_AGENT_DEFAULT_WEBHOOK=https://your-ai-agent.com/webhook

# === Server ===
PORT=3000
HOST=0.0.0.0

# === Admin / webhook secrets (fail-closed) ===
# These admin endpoints are DISABLED unless their secret is set (min 8 chars).
# No guessable default — set a strong random value only if you use them.
MIGRATE_TOKEN=          # api migrate.runGovData (DB migrations)
BULK_IMPORT_TOKEN=      # bulk client import (router + /api/admin/import-clients)
VOICE_WEBHOOK_TOKEN=    # external voice webhook (voice.createTask)
